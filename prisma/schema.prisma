generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Question {
  id       Int       @id @default(autoincrement())
  question String
  answer   String
  keywords Keyword[]

  @@map("questions")
}

model Keyword {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  questions Question[]

  @@map("keywords")
}